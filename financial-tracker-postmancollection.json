{
  "info": {
    "name": "Finance Tracker - Combined Scenarios (1 Core, 2 Negative, 3 Edge)",
    "_postman_id": "d7f4d8dd-0d18-4f4f-9d11-8d9bf8d84755",
    "description": "Combined collection with 3 folders: 1) Core functional scenarios, 2) Required negative scenarios, 3) Additional edge-case scenarios.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://127.0.0.1:5000" },
    { "key": "admin_email", "value": "asmaa@example.com" },
    { "key": "admin_token", "value": "" },
    { "key": "record_id", "value": "1" }
  ],
  "item": [
    {
      "name": "1) Core Functional Scenarios",
      "item": [
        {
          "name": "01 - Health / Root (optional)",
          "request": { "method": "GET", "url": "{{base_url}}/" }
        },
        {
          "name": "02 - Create Admin User",
          "request": {
            "method": "POST",
            "header": [
              { "key": "role", "value": "admin" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Asmaa Admin\",\n  \"email\": \"asmaa@example.com\",\n  \"role\": \"admin\",\n  \"status\": true\n}"
            },
            "url": "{{base_url}}/users"
          }
        },
        {
          "name": "03 - Create Analyst User",
          "request": {
            "method": "POST",
            "header": [
              { "key": "role", "value": "admin" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Anu Analyst\",\n  \"email\": \"anu@example.com\",\n  \"role\": \"analyst\",\n  \"status\": true\n}"
            },
            "url": "{{base_url}}/users"
          }
        },
        {
          "name": "04 - Create Viewer User",
          "request": {
            "method": "POST",
            "header": [
              { "key": "role", "value": "admin" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Vee Viewer\",\n  \"email\": \"vee@example.com\",\n  \"role\": \"viewer\",\n  \"status\": true\n}"
            },
            "url": "{{base_url}}/users"
          }
        },
        {
          "name": "05 - Get Users (viewer allowed)",
          "request": {
            "method": "GET",
            "header": [{ "key": "role", "value": "viewer" }],
            "url": "{{base_url}}/users"
          }
        },
        {
          "name": "06 - Mint Admin Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "let json = {};",
                  "try { json = pm.response.json(); } catch(e) {}",
                  "if (json.access_token) {",
                  "  pm.collectionVariables.set('admin_token', json.access_token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "role", "value": "admin" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"{{admin_email}}\"\n}" },
            "url": "{{base_url}}/auth/token"
          }
        },
        {
          "name": "07 - Create Income Record (admin + JWT)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "role", "value": "admin" },
              { "key": "Authorization", "value": "Bearer {{admin_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": 2500,\n  \"type\": \"income\",\n  \"category\": \"Salary\",\n  \"date\": \"2026-04-02\",\n  \"note\": \"April salary\"\n}"
            },
            "url": "{{base_url}}/records"
          }
        },
        {
          "name": "08 - Create Expense Record (admin + JWT)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "role", "value": "admin" },
              { "key": "Authorization", "value": "Bearer {{admin_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": 700,\n  \"type\": \"expense\",\n  \"category\": \"Rent\",\n  \"date\": \"2026-04-02\",\n  \"note\": \"April rent\"\n}"
            },
            "url": "{{base_url}}/records"
          }
        },
        {
          "name": "09 - List Records (viewer)",
          "request": {
            "method": "GET",
            "header": [{ "key": "role", "value": "viewer" }],
            "url": "{{base_url}}/records"
          }
        },
        {
          "name": "10 - Update Record (admin)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "role", "value": "admin" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": 2600,\n  \"type\": \"income\",\n  \"category\": \"Salary\",\n  \"date\": \"2026-04-02\",\n  \"note\": \"Updated salary\"\n}"
            },
            "url": "{{base_url}}/records/{{record_id}}"
          }
        },
        {
          "name": "11 - Summary Income (analyst)",
          "request": {
            "method": "GET",
            "header": [{ "key": "role", "value": "analyst" }],
            "url": "{{base_url}}/summary/income"
          }
        },
        {
          "name": "12 - Summary Expense (analyst)",
          "request": {
            "method": "GET",
            "header": [{ "key": "role", "value": "analyst" }],
            "url": "{{base_url}}/summary/expense"
          }
        },
        {
          "name": "13 - Summary Balance (viewer)",
          "request": {
            "method": "GET",
            "header": [{ "key": "role", "value": "viewer" }],
            "url": "{{base_url}}/summary/balance"
          }
        },
        {
          "name": "14 - Summary Category (viewer)",
          "request": {
            "method": "GET",
            "header": [{ "key": "role", "value": "viewer" }],
            "url": "{{base_url}}/summary/category"
          }
        }
      ]
    },

    {
      "name": "2) Required Negative Scenarios",
      "item": [
        {
          "name": "NEG-01 Missing Role Header -> 401",
          "request": { "method": "GET", "url": "{{base_url}}/users" }
        },
        {
          "name": "NEG-02 Viewer on Summary Income -> 403",
          "request": {
            "method": "GET",
            "header": [{ "key": "role", "value": "viewer" }],
            "url": "{{base_url}}/summary/income"
          }
        },
        {
          "name": "NEG-03 Analyst Create Record -> 403",
          "request": {
            "method": "POST",
            "header": [
              { "key": "role", "value": "analyst" },
              { "key": "Authorization", "value": "Bearer {{admin_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": 100,\n  \"type\": \"expense\",\n  \"category\": \"Food\",\n  \"date\": \"2026-04-02\",\n  \"note\": \"Should fail\"\n}"
            },
            "url": "{{base_url}}/records"
          }
        },
        {
          "name": "NEG-04 Admin Create Record without JWT -> 401",
          "request": {
            "method": "POST",
            "header": [
              { "key": "role", "value": "admin" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": 100,\n  \"type\": \"expense\",\n  \"category\": \"Food\",\n  \"date\": \"2026-04-02\"\n}"
            },
            "url": "{{base_url}}/records"
          }
        },
        {
          "name": "NEG-05 Invalid amount (0) -> 400",
          "request": {
            "method": "POST",
            "header": [
              { "key": "role", "value": "admin" },
              { "key": "Authorization", "value": "Bearer {{admin_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": 0,\n  \"type\": \"expense\",\n  \"category\": \"Food\",\n  \"date\": \"2026-04-02\"\n}"
            },
            "url": "{{base_url}}/records"
          }
        },
        {
          "name": "NEG-06 Invalid type -> 400",
          "request": {
            "method": "POST",
            "header": [
              { "key": "role", "value": "admin" },
              { "key": "Authorization", "value": "Bearer {{admin_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": 100,\n  \"type\": \"profit\",\n  \"category\": \"Food\",\n  \"date\": \"2026-04-02\"\n}"
            },
            "url": "{{base_url}}/records"
          }
        },
        {
          "name": "NEG-07 Invalid date format -> 400",
          "request": {
            "method": "POST",
            "header": [
              { "key": "role", "value": "admin" },
              { "key": "Authorization", "value": "Bearer {{admin_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": 100,\n  \"type\": \"expense\",\n  \"category\": \"Food\",\n  \"date\": \"02-04-2026\"\n}"
            },
            "url": "{{base_url}}/records"
          }
        },
        {
          "name": "NEG-08 Duplicate email -> 400",
          "request": {
            "method": "POST",
            "header": [
              { "key": "role", "value": "admin" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Duplicate\",\n  \"email\": \"asmaa@example.com\",\n  \"role\": \"admin\"\n}"
            },
            "url": "{{base_url}}/users"
          }
        },
        {
          "name": "NEG-09 Invalid filter user_id -> 400",
          "request": {
            "method": "GET",
