            "url": "{{base_url}}/records?user_id=abc"
          }
        },
        {
          "name": "NEG-10 Invalid filter type -> 400",
          "request": {
            "method": "GET",
            "header": [{ "key": "role", "value": "viewer" }],
            "url": "{{base_url}}/records?type=profit"
          }
        },
        {
          "name": "NEG-11 Invalid filter start_date -> 400",
          "request": {
            "method": "GET",
            "header": [{ "key": "role", "value": "viewer" }],
            "url": "{{base_url}}/records?start_date=2026/04/02"
          }
        },
        {
          "name": "NEG-12 Update missing record -> 404",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "role", "value": "admin" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": 111,\n  \"type\": \"income\",\n  \"category\": \"Test\",\n  \"date\": \"2026-04-02\",\n  \"note\": \"missing id\"\n}"
            },
            "url": "{{base_url}}/records/99999"
          }
        },
        {
          "name": "NEG-13 Delete missing record -> 404",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "role", "value": "admin" }],
            "url": "{{base_url}}/records/99999"
          }
        }
      ]
    },

    {
      "name": "3) Additional Edge Scenarios",
      "item": [
        {
          "name": "EDGE-01 Role header case-insensitive admin -> should pass",
          "request": {
            "method": "GET",
            "header": [{ "key": "role", "value": "ADMIN" }],
            "url": "{{base_url}}/users"
          }
        },
        {
          "name": "EDGE-02 Role header with spaces -> should pass (normalized)",
          "request": {
            "method": "GET",
            "header": [{ "key": "role", "value": "  admin  " }],
            "url": "{{base_url}}/users"
          }
        },
        {
          "name": "EDGE-03 Invalid role value -> forbidden",
          "request": {
            "method": "GET",
            "header": [{ "key": "role", "value": "manager" }],
            "url": "{{base_url}}/users"
          }
        },
        {
          "name": "EDGE-04 Mint token with invalid role header -> 403",
          "request": {
            "method": "POST",
            "header": [
              { "key": "role", "value": "manager" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"{{admin_email}}\"\n}" },
            "url": "{{base_url}}/auth/token"
          }
        },
        {
          "name": "EDGE-05 Mint token with unknown email -> 404",
          "request": {
            "method": "POST",
            "header": [
              { "key": "role", "value": "admin" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"notfound@example.com\"\n}" },
            "url": "{{base_url}}/auth/token"
          }
        },
        {
          "name": "EDGE-06 Mint token role mismatch (analyst header for admin email) -> 403",
          "request": {
            "method": "POST",
            "header": [
              { "key": "role", "value": "analyst" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"{{admin_email}}\"\n}" },
            "url": "{{base_url}}/auth/token"
          }
        },
        {
          "name": "EDGE-07 Create inactive user (admin)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "role", "value": "admin" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Inactive User\",\n  \"email\": \"inactive@example.com\",\n  \"role\": \"viewer\",\n  \"status\": false\n}"
            },
            "url": "{{base_url}}/users"
          }
        },
        {
          "name": "EDGE-08 Mint token for inactive user -> 404",
          "request": {
            "method": "POST",
            "header": [
              { "key": "role", "value": "viewer" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"inactive@example.com\"\n}" },
            "url": "{{base_url}}/auth/token"
          }
        },
        {
          "name": "EDGE-09 Create record malformed auth scheme -> 401",
          "request": {
            "method": "POST",
            "header": [
              { "key": "role", "value": "admin" },
              { "key": "Authorization", "value": "Token {{admin_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": 100,\n  \"type\": \"expense\",\n  \"category\": \"Food\",\n  \"date\": \"2026-04-02\"\n}"
            },
            "url": "{{base_url}}/records"
          }
        },
        {
          "name": "EDGE-10 Create record with fake token -> 401",
          "request": {
            "method": "POST",
            "header": [
              { "key": "role", "value": "admin" },
              { "key": "Authorization", "value": "Bearer this.is.not.valid" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": 100,\n  \"type\": \"expense\",\n  \"category\": \"Food\",\n  \"date\": \"2026-04-02\"\n}"
            },
            "url": "{{base_url}}/records"
          }
        },
        {
          "name": "EDGE-11 Create record missing category -> 400",
          "request": {
            "method": "POST",
            "header": [
              { "key": "role", "value": "admin" },
              { "key": "Authorization", "value": "Bearer {{admin_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": 100,\n  \"type\": \"expense\",\n  \"date\": \"2026-04-02\"\n}"
            },
            "url": "{{base_url}}/records"
          }
        },
        {
          "name": "EDGE-12 Create record missing note (optional) -> 201",
          "request": {
            "method": "POST",
            "header": [
              { "key": "role", "value": "admin" },
              { "key": "Authorization", "value": "Bearer {{admin_token}}" },
