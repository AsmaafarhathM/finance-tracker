            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": 150,\n  \"type\": \"expense\",\n  \"category\": \"Snacks\",\n  \"date\": \"2026-04-02\"\n}"
            },
            "url": "{{base_url}}/records"
          }
        },
        {
          "name": "EDGE-13 Update record invalid amount type string -> 400",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "role", "value": "admin" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": \"abc\",\n  \"type\": \"income\",\n  \"category\": \"Salary\",\n  \"date\": \"2026-04-02\",\n  \"note\": \"bad amount\"\n}"
            },
            "url": "{{base_url}}/records/{{record_id}}"
          }
        },
        {
          "name": "EDGE-14 Update record missing required field -> 400",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "role", "value": "admin" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": 120,\n  \"type\": \"income\",\n  \"date\": \"2026-04-02\"\n}"
            },
            "url": "{{base_url}}/records/{{record_id}}"
          }
        },
        {
          "name": "EDGE-15 Records filter start_date > end_date (observe behavior)",
          "request": {
            "method": "GET",
            "header": [{ "key": "role", "value": "viewer" }],
            "url": "{{base_url}}/records?start_date=2026-05-01&end_date=2026-04-01"
          }
        },
        {
          "name": "EDGE-16 Records filter valid range + type",
          "request": {
            "method": "GET",
            "header": [{ "key": "role", "value": "viewer" }],
            "url": "{{base_url}}/records?start_date=2026-04-01&end_date=2026-04-30&type=income"
          }
        },
        {
          "name": "EDGE-17 Delete existing record (if exists)",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "role", "value": "admin" }],
            "url": "{{base_url}}/records/{{record_id}}"
          }
        },
        {
          "name": "EDGE-18 Delete same record again -> 404",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "role", "value": "admin" }],
            "url": "{{base_url}}/records/{{record_id}}"
          }
        },
        {
          "name": "EDGE-19 Summary balance as admin",
          "request": {
            "method": "GET",
            "header": [{ "key": "role", "value": "admin" }],
            "url": "{{base_url}}/summary/balance"
          }
        },
        {
          "name": "EDGE-20 Summary category as analyst",
          "request": {
            "method": "GET",
            "header": [{ "key": "role", "value": "analyst" }],
